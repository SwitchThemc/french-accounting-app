    { "key": "reports", "path": "/reports" },
    { "key": "einvoicing", "path": "/einvoicing" },
    { "key": "settings", "path": "/settings" }
  ],
  "handoff_payload": {
    "allowed_fields": ["hub_return_url", "launch_target", "permissions", "session_bootstrap", "handoff_payload", "hub_state"]
  },
  "ownership": {
    "repo_path": "/Users/switchthemc/french-accounting-app",
    "manager_skill": "/Users/switchthemc/.codex/skills/hinnou-hub-manager/SKILL.md"
  },
  "standalone_smoke_check": "npm run build",
